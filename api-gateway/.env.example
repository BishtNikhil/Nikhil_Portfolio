# API Gateway Environment Variables

# Generative AI API Key (Google AI / Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Vertex AI Vector Search Configuration
# These are required AFTER you deploy your Vertex AI Index Endpoint
VERTEX_ENDPOINT_DOMAIN=123456789.us-central1-123456789.vdb.vertexai.goog
VERTEX_INDEX_ENDPOINT_ID=your_index_endpoint_id
VERTEX_DEPLOYED_INDEX_ID=your_deployed_index_id

# WakaTime Language Tracking
WAKATIME_API_KEY=your_wakatime_api_key_here

# GitHub Personal Access Token (optional — increases rate limit to 5000/hr)
# GITHUB_TOKEN=your_github_pat_here

# GCP Project ID (if not hardcoded)
# PROJECT_ID=your_project_id_here
